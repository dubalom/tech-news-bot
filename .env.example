# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Channel/chat ID to send news to (e.g. @parse_ch or numeric ID like -1001234567890)
TELEGRAM_CHAT_ID=@parse_ch

# Anthropic API Key for Claude summarization
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Schedule time (24h format, Moscow timezone by default)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Timezone (see pytz timezone list)
TIMEZONE=Europe/Moscow

# Max articles to fetch per site
MAX_ARTICLES_PER_SITE=10
